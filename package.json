{
    "name": "obsidian-habr-importer-plugin",
    "version": "0.2.3",
    "description": "Download Habr articles, convert to Markdown, and save into your vault",
    "main": "main.js",
    "scripts": {
        "dev": "node esbuild.config.mjs",
        "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
        "release": "npm run build && ./release.sh",
        "lint": "eslint"
    },
    "author": "playmean",
    "license": "MIT",
    "dependencies": {
        "turndown": "^7.2.2",
        "turndown-plugin-gfm": "^1.0.2"
    },
    "devDependencies": {
        "@trivago/prettier-plugin-sort-imports": "^4.0.0",
        "@types/node": "^16.11.6",
        "@types/turndown": "^5.0.6",
        "@typescript-eslint/eslint-plugin": "^8.53.1",
        "@typescript-eslint/parser": "^8.53.1",
        "esbuild": "^0.17.3",
        "eslint": "^9.39.2",
        "eslint-plugin-obsidianmd": "^0.1.9",
        "obsidian": "latest",
        "prettier": "^3.3.3",
        "semverity": "^0.4.1",
        "tslib": "^2.4.0",
        "typescript": "^4.9.5"
    }
}
